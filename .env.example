# Binance Spot Trading Bot Configuration
# Copy this file to .env and fill in your API keys

# ==== BINANCE API KEYS (TESTNET) ====
# For testnet, get keys at: https://testnet.binance.vision/
# These are used when in DEMO mode
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# ==== BINANCE API KEYS (REAL/MAINNET) ====
# For real trading, get keys at: https://www.binance.com/en/my/settings/api-management
# These are used when you switch to REAL mode with /real confirm
# WARNING: These keys will be used for REAL MONEY trading!
REAL_API_KEY=your_real_api_key_here
REAL_API_SECRET=your_real_api_secret_here

# ==== TRADING MODE ====
# Use Binance testnet (true/false)
TESTNET=true

# Paper trading - logs trades but doesn't execute them (true/false)
DRY_RUN=true

# ==== TRADING PARAMETERS ====
# Percentage of wallet balance to use per trade (0.0 - 1.0)
# 0.20 = 20% of available balance
POSITION_PCT=0.20

# Minimum prediction threshold to trigger a trade
# 0.003 = 0.30% predicted move (covers 0.20% round-trip fees)
PREDICTION_THRESHOLD=0.003

# Prediction scaling factor to reduce overprediction
# Model tends to predict larger moves than reality
# 0.5 = use 50% of predicted value as target
# Example: Model predicts +0.4% -> Target becomes +0.2%
PREDICTION_SCALE=0.5

# ==== SMART EXIT SETTINGS ====
# Minimum profit required to exit when signal turns negative
# 0.0025 = 0.25% (covers fees + small profit)
MIN_PROFIT_TO_EXIT=0.0025

# Stop-loss percentage (negative value)
# -0.05 = -5% loss triggers automatic exit
STOP_LOSS_PCT=-0.05

# ==== FEE SETTINGS ====
# Use BNB for fee discount (0.1% -> 0.075%)
USE_BNB_FOR_FEES=true

# ==== TELEGRAM NOTIFICATIONS ====
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=7801619375:AAEukkjycy2ZW9jy3-MOQhAUdxlNGPFoCTU

# Get your chat ID from @userinfobot or @getidsbot
TELEGRAM_CHAT_ID=7975288380

# Enable/disable Telegram notifications
TELEGRAM_ENABLED=true

# ==== MULTI-COIN AUTO-TRADING ====
# Coins to auto-trade (comma separated, or 'all' for all 20 coins)
AUTO_TRADE_COINS=BTC,ETH,SOL

# Default timeframe for predictions (15m or 1h)
DEFAULT_TIMEFRAME=15m

# Maximum positions at once
MAX_POSITIONS=5

# ==== RASPBERRY PI OPTIMIZATION ====
# Max models to keep loaded in memory (LRU cache)
# Lower = less RAM, higher = faster predictions
MAX_LOADED_MODELS=5

# ==== TRADING MODE ====
# Trading mode: spot or futures
TRADING_MODE=spot

# Futures leverage (1-125, only used if TRADING_MODE=futures)
LEVERAGE=5

# Margin type for futures: isolated or cross
MARGIN_TYPE=isolated

# ==== SAFETY LIMITS ====
# Daily loss limit (trading stops if daily loss exceeds this)
# -5.0 = -5% daily loss limit
DAILY_LOSS_LIMIT_PCT=-25.0

# Maximum trades per day
MAX_DAILY_TRADES=50

# Minimum balance protection (won't trade if balance drops below)
MIN_BALANCE_USDT=2.0
